    {"id":"tpl-1","type":"rectangle","x":10,"y":826,"width":610,"height":210,"strokeColor":"#059669","backgroundColor":"#f0fdf4","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":210,"version":1,"versionNonce":210,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"id":"tpl-1-t","type":"text","x":18,"y":832,"width":594,"height":200,"strokeColor":"#14532d","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":211,"version":1,"versionNonce":211,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"👋 SAUDAÇÃO\n\nOlá! Bem-vindo à *{pizzaria}*!\n\nComo posso te ajudar?\n🍕 *cardápio* — ver nossas pizzas\n🛵 *entrega* — bairros atendidos\n💰 *taxa* — valor do frete\n🕐 *horário* — quando abrimos\n📦 *pedido* — acompanhar pedido\n\nOu acesse: {link-da-loja}","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":12,"containerId":null,"originalText":"👋 SAUDAÇÃO\n\nOlá! Bem-vindo à *{pizzaria}*!\n\nComo posso te ajudar?\n🍕 *cardápio* — ver nossas pizzas\n🛵 *entrega* — bairros atendidos\n💰 *taxa* — valor do frete\n🕐 *horário* — quando abrimos\n📦 *pedido* — acompanhar pedido\n\nOu acesse: {link-da-loja}","lineHeight":1.4},

    {"id":"tpl-2","type":"rectangle","x":630,"y":826,"width":610,"height":210,"strokeColor":"#d97706","backgroundColor":"#fffbeb","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":212,"version":1,"versionNonce":212,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"id":"tpl-2-t","type":"text","x":638,"y":832,"width":594,"height":200,"strokeColor":"#78350f","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":213,"version":1,"versionNonce":213,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"🛵 ENTREGA / BAIRROS\n(dados buscados do Supabase em tempo real)\n\n*Bairros que atendemos:*\n{bairros_atendidos — linha por linha}\n\n💰 Taxa de entrega: R$ {taxa_entrega}\n🛵 Para retirada no local: grátis!\n\nFaça seu pedido: {link-da-loja}","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":12,"containerId":null,"originalText":"🛵 ENTREGA / BAIRROS\n(dados buscados do Supabase em tempo real)\n\n*Bairros que atendemos:*\n{bairros_atendidos — linha por linha}\n\n💰 Taxa de entrega: R$ {taxa_entrega}\n🛵 Para retirada no local: grátis!\n\nFaça seu pedido: {link-da-loja}","lineHeight":1.4},

