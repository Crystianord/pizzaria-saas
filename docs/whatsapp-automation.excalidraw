    {"id":"tpl-4-t","type":"text","x":1878,"y":832,"width":694,"height":200,"strokeColor":"#7f1d1d","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":217,"version":1,"versionNonce":217,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"🔔 NOTIFICAÇÕES AUTOMÁTICAS (Fluxo 2)\n\n✅ preparo:    \"Seu pedido foi aceito! 🍕 Acompanhe: {link}/pedido/{id}\"\n\n🛵 a_caminho: \"Seu pedido saiu para entrega! Acompanhe: {link}/pedido/{id}\"\n\n🎉 entregue:  \"{nome}, obrigado pela preferência! Até a próxima! 🍕\"","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":12,"containerId":null,"originalText":"🔔 NOTIFICAÇÕES AUTOMÁTICAS (Fluxo 2)\n\n✅ preparo:    \"Seu pedido foi aceito! 🍕 Acompanhe: {link}/pedido/{id}\"\n\n🛵 a_caminho: \"Seu pedido saiu para entrega! Acompanhe: {link}/pedido/{id}\"\n\n🎉 entregue:  \"{nome}, obrigado pela preferência! Até a próxima! 🍕\"","lineHeight":1.4},

