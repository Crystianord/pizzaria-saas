    {"id":"t-b1","type":"text","x":20,"y":228,"width":640,"height":100,"angle":0,"strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":12,"version":1,"versionNonce":12,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"📋 MenuClient.js\nCardápio interativo: lista produtos por categoria, gerencia o\ncarrinho, calcula o total, habilita meia a meia. Tudo que o\ncliente vê e clica no site público da pizzaria.","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":13,"containerId":null,"originalText":"📋 MenuClient.js\nCardápio interativo: lista produtos por categoria, gerencia o\ncarrinho, calcula o total, habilita meia a meia. Tudo que o\ncliente vê e clica no site público da pizzaria.","lineHeight":1.4},

