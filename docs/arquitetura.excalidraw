    {"id":"t-b2","type":"text","x":20,"y":346,"width":640,"height":88,"angle":0,"strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":14,"version":1,"versionNonce":14,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"📡 OrderStatus.js  (pedido/[id])\nAcompanhamento do pedido em tempo real. O cliente vê o\nstatus mudar (novo→preparo→caminho→entregue) sem recarregar\na página. Usa Supabase Realtime (WebSocket).","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":13,"containerId":null,"originalText":"📡 OrderStatus.js  (pedido/[id])\nAcompanhamento do pedido em tempo real. O cliente vê o\nstatus mudar (novo→preparo→caminho→entregue) sem recarregar\na página. Usa Supabase Realtime (WebSocket).","lineHeight":1.4},

