    {"id":"t-sql2","type":"text","x":1290,"y":1088,"width":580,"height":62,"angle":0,"strokeColor":"#164e63","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":91,"version":1,"versionNonce":91,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"002-entregador-disponivel.sql\nAdiciona coluna 'disponivel' boolean na tabela entregadores.\nSepara 'cadastrado no sistema' de 'trabalhando hoje'.","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":13,"containerId":null,"originalText":"002-entregador-disponivel.sql\nAdiciona coluna 'disponivel' boolean na tabela entregadores.\nSepara 'cadastrado no sistema' de 'trabalhando hoje'.","lineHeight":1.4},

    {"id":"r-sql3","type":"rectangle","x":1280,"y":1161,"width":600,"height":86,"angle":0,"strokeColor":"#a5f3fc","backgroundColor":"#ecfeff","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":92,"version":1,"versionNonce":92,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"id":"t-sql3","type":"text","x":1290,"y":1167,"width":580,"height":76,"angle":0,"strokeColor":"#164e63","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":93,"version":1,"versionNonce":93,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"003-security-hardening.sql\nTimeouts: anon 3s, authenticated 10s. Revoga DDL de todos\nos roles de app. Isola tabelas internas (admin_stores, entre-\ngadores, funcionarios) de acesso anon. Role app_api (só DML).","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":13,"containerId":null,"originalText":"003-security-hardening.sql\nTimeouts: anon 3s, authenticated 10s. Revoga DDL de todos\nos roles de app. Isola tabelas internas (admin_stores, entre-\ngadores, funcionarios) de acesso anon. Role app_api (só DML).","lineHeight":1.4},

    {"id":"r-db1","type":"rectangle","x":1932,"y":220,"width":618,"height":130,"angle":0,"strokeColor":"#6ee7b7","backgroundColor":"#d1fae5","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":100,"version":1,"versionNonce":100,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"id":"t-db1","type":"text","x":1942,"y":226,"width":598,"height":120,"angle":0,"strokeColor":"#064e3b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":101,"version":1,"versionNonce":101,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"🔐 AUTH — Autenticação dos Admins\nJWT gerado no login, armazenado em cookie httpOnly. O\nmiddleware renova o token automaticamente antes de expirar.\nCada loja tem seu próprio usuário em auth.users + admin_stores.\nO Supabase cuida de expiração, refresh e revogação.","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":13,"containerId":null,"originalText":"🔐 AUTH — Autenticação dos Admins\nJWT gerado no login, armazenado em cookie httpOnly. O\nmiddleware renova o token automaticamente antes de expirar.\nCada loja tem seu próprio usuário em auth.users + admin_stores.\nO Supabase cuida de expiração, refresh e revogação.","lineHeight":1.4},

    {"id":"r-db2","type":"rectangle","x":1932,"y":358,"width":618,"height":220,"angle":0,"strokeColor":"#6ee7b7","backgroundColor":"#d1fae5","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":102,"version":1,"versionNonce":102,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"id":"t-db2","type":"text","x":1942,"y":364,"width":598,"height":210,"angle":0,"strokeColor":"#064e3b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":103,"version":1,"versionNonce":103,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"🗃️ POSTGRESQL — 11 Tabelas\nstores          → dados da pizzaria (nome, slug, config)\nadmin_stores    → mapeia user do auth → loja\norders          → pedidos (status, cliente, total)\norder_items     → itens de cada pedido\ncategories      → categorias do cardápio\nproducts        → produtos (nome, foto, ativo)\nproduct_variants → tamanhos e preços\npromotions      → descontos ativos por produto\nentregadores    → motoristas (token, ativo, disponivel)\nfuncionarios    → equipe da pizzaria + diária\nintercorrencias → ajustes da folha (falta, hora extra)","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":13,"containerId":null,"originalText":"🗃️ POSTGRESQL — 11 Tabelas\nstores          → dados da pizzaria (nome, slug, config)\nadmin_stores    → mapeia user do auth → loja\norders          → pedidos (status, cliente, total)\norder_items     → itens de cada pedido\ncategories      → categorias do cardápio\nproducts        → produtos (nome, foto, ativo)\nproduct_variants → tamanhos e preços\npromotions      → descontos ativos por produto\nentregadores    → motoristas (token, ativo, disponivel)\nfuncionarios    → equipe da pizzaria + diária\nintercorrencias → ajustes da folha (falta, hora extra)","lineHeight":1.4},

    {"id":"r-db3","type":"rectangle","x":1932,"y":586,"width":618,"height":116,"angle":0,"strokeColor":"#6ee7b7","backgroundColor":"#d1fae5","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":104,"version":1,"versionNonce":104,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"id":"t-db3","type":"text","x":1942,"y":592,"width":598,"height":106,"angle":0,"strokeColor":"#064e3b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":105,"version":1,"versionNonce":105,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"🖼️ STORAGE — Imagens dos Produtos\nBucket 'product-images'. Upload requer autenticação (admin).\nLeitura pública para exibição no cardápio. As URLs ficam em\nproducts.foto_url e stores.imagem_fundo_url.","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":13,"containerId":null,"originalText":"🖼️ STORAGE — Imagens dos Produtos\nBucket 'product-images'. Upload requer autenticação (admin).\nLeitura pública para exibição no cardápio. As URLs ficam em\nproducts.foto_url e stores.imagem_fundo_url.","lineHeight":1.4},

    {"id":"r-db4","type":"rectangle","x":1932,"y":710,"width":618,"height":116,"angle":0,"strokeColor":"#6ee7b7","backgroundColor":"#d1fae5","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":106,"version":1,"versionNonce":106,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"id":"t-db4","type":"text","x":1942,"y":716,"width":598,"height":106,"angle":0,"strokeColor":"#064e3b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":107,"version":1,"versionNonce":107,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"⚡ REALTIME — WebSocket de Atualizações\nAdmin recebe pedidos novos sem refresh da página.\nCliente vê o status do pedido mudar ao vivo.\nEntregador vê pedidos atribuídos em tempo real.\nCanais: store-orders-{storeId}, order-{orderId}.","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":13,"containerId":null,"originalText":"⚡ REALTIME — WebSocket de Atualizações\nAdmin recebe pedidos novos sem refresh da página.\nCliente vê o status do pedido mudar ao vivo.\nEntregador vê pedidos atribuídos em tempo real.\nCanais: store-orders-{storeId}, order-{orderId}.","lineHeight":1.4},

