    {"id":"t-sql1","type":"text","x":1290,"y":1009,"width":580,"height":62,"angle":0,"strokeColor":"#164e63","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":89,"version":1,"versionNonce":89,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"supabase/rls.sql  +  001-security-fixes.sql\nRLS: cada admin acessa só sua loja. Anon só lê pedidos das\núltimas 24h. Anon não pode inserir orders diretamente.","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":13,"containerId":null,"originalText":"supabase/rls.sql  +  001-security-fixes.sql\nRLS: cada admin acessa só sua loja. Anon só lê pedidos das\núltimas 24h. Anon não pode inserir orders diretamente.","lineHeight":1.4},

