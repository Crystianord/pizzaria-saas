    {"id":"t-legend","type":"text","x":20,"y":1112,"width":640,"height":90,"angle":0,"strokeColor":"#475569","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":301,"version":1,"versionNonce":301,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"LEGENDA DOS FLUXOS:\n→ laranja: requisição Browser → Server Actions (via formulários e botões)\n→ verde:   Server Actions → Supabase (queries, inserts, updates)\n- - azul:  Browser → Realtime WebSocket (pedidos e status ao vivo)","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":12,"containerId":null,"originalText":"LEGENDA DOS FLUXOS:\n→ laranja: requisição Browser → Server Actions (via formulários e botões)\n→ verde:   Server Actions → Supabase (queries, inserts, updates)\n- - azul:  Browser → Realtime WebSocket (pedidos e status ao vivo)","lineHeight":1.5}
